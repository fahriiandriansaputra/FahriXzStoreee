*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:'Poppins',sans-serif;
}

body{
background:#020617;
color:white;
overflow-x:hidden;
}

.promo-bar{
padding:12px;
text-align:center;
background:#2563eb;
font-weight:600;
}

.navbar{
display:flex;
justify-content:space-between;
align-items:center;
padding:20px;
background:#0f172a;
position:sticky;
top:0;
z-index:999;
}

.nav-links{
display:flex;
gap:20px;
}

.nav-links a{
color:white;
text-decoration:none;
}

.hero{
display:grid;
grid-template-columns:1fr 1fr;
align-items:center;
padding:60px 5%;
gap:30px;
}

.hero-image{
width:100%;
border-radius:24px;
}

.btn-primary{
display:inline-block;
margin-top:20px;
padding:14px 24px;
background:#2563eb;
border-radius:16px;
color:white;
text-decoration:none;
}

.slider{
overflow:hidden;
padding:20px;
}

.slider-track{
display:flex;
gap:20px;
transition:.5s;
}

.slider-track img{
width:100%;
border-radius:20px;
}

.product-grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:20px;
padding:20px;
}

.product-card{
background:#0f172a;
padding:20px;
border-radius:20px;
transition:.3s;
}

.product-card:hover{
transform:translateY(-5px);
}

.stats{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(200px,1fr));
gap:20px;
padding:20px;
}

.stats-card{
background:#0f172a;
padding:30px;
border-radius:20px;
text-align:center;
}

.testi-grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(200px,1fr));
gap:20px;
padding:20px;
}

.testi-card{
background:#0f172a;
padding:20px;
border-radius:20px;
}

.faq{
padding:20px;
}

.faq-item{
margin-bottom:20px;
}

.faq-question{
width:100%;
padding:16px;
background:#0f172a;
border:none;
color:white;
border-radius:12px;
cursor:pointer;
}

.faq-answer{
display:none;
padding:15px;
background:#111827;
border-radius:12px;
margin-top:10px;
}

.floating-wa{
position:fixed;
bottom:20px;
right:20px;
width:60px;
height:60px;
background:#22c55e;
display:flex;
justify-content:center;
align-items:center;
border-radius:50%;
font-size:28px;
text-decoration:none;
color:white;
}

/* =========================
NOTIFICATION BUTTON
========================= */

.notif-btn{

position:fixed;

bottom:80px;

left:20px;

padding:14px 18px;

border:none;

border-radius:14px;

background:#0ea5e9;

color:white;

cursor:pointer;

z-index:999;

}

/* =========================
TOAST
========================= */

.toast{

position:fixed;

top:30px;

right:-400px;

background:#2563eb;

padding:16px 25px;

border-radius:14px;

color:white;

z-index:9999;

transition:.4s;

box-shadow:
0 0 20px rgba(37,99,235,.4);

}

.toast.show{

right:30px;

}

.toast.error{
background:#dc2626;
}

/* =========================
404 PAGE
========================= */

.notfound-page{

height:100vh;

display:flex;

flex-direction:column;

justify-content:center;

align-items:center;

background:#020617;

color:white;

text-align:center;

}

.notfound-page h1{

font-size:120px;

margin-bottom:10px;

}

.notfound-page p{

margin-bottom:25px;

font-size:20px;

color:#94a3b8;

}

/* =========================
PRODUCT PAGE
========================= */

.products-page{

padding:60px 30px;

min-height:100vh;

background:#020617;

color:white;

}

.section-title{

text-align:center;

margin-bottom:40px;

}

.section-title h1{

font-size:45px;

margin-bottom:10px;

}

.section-title p{

color:#94a3b8;

}

.search-box{

max-width:600px;

margin:auto;

margin-bottom:25px;

}

.search-box input{

width:100%;

padding:18px;

border:none;

border-radius:18px;

background:#0f172a;

color:white;

}

.category-filter{

display:flex;

gap:15px;

justify-content:center;

flex-wrap:wrap;

margin-bottom:40px;

}

.category-filter button{

padding:14px 25px;

border:none;

border-radius:16px;

background:#0f172a;

color:white;

cursor:pointer;

transition:.3s;

}

.category-filter button.active,
.category-filter button:hover{

background:#2563eb;

}

.product-grid{

display:grid;

grid-template-columns:
repeat(auto-fit,minmax(280px,1fr));

gap:25px;

}

.product-card{

background:#0f172a;

padding:25px;

border-radius:24px;

transition:.3s;

border:
1px solid rgba(255,255,255,.05);

}

.product-card:hover{

transform:translateY(-5px);

box-shadow:
0 0 20px rgba(37,99,235,.3);

}

.product-card h3{

margin-bottom:10px;

}

.product-card p{

color:#94a3b8;

margin-bottom:20px;

}

.product-card h2{

margin-bottom:20px;

}

.btn-primary{

padding:14px 20px;

border:none;

border-radius:14px;

background:#2563eb;

color:white;

cursor:pointer;

}

/* =========================
TOP LOADING BAR
========================= */

#topLoadingBar{

position:fixed;

top:0;
left:0;

height:4px;

width:0;

background:#2563eb;

z-index:999999;

transition:
width 1s ease,
opacity .5s ease;

}

/* =========================
PROMO POPUP
========================= */

.promo-popup{

position:fixed;

inset:0;

background:rgba(0,0,0,.7);

display:flex;

justify-content:center;

align-items:center;

z-index:9999;

backdrop-filter:blur(10px);

}

.promo-content{

background:#0f172a;

padding:40px;

border-radius:30px;

text-align:center;

width:90%;
max-width:450px;

animation:popupShow .4s ease;

}

.promo-content h2{
margin-bottom:15px;
}

.promo-content p{

color:#cbd5e1;

margin-bottom:25px;

}

.promo-content button{

padding:14px 25px;

border:none;

border-radius:14px;

background:#2563eb;

color:white;

cursor:pointer;

}

@keyframes popupShow{

from{

opacity:0;
transform:scale(.8);

}

to{

opacity:1;
transform:scale(1);

}

/* =========================
GLOBAL LOADER
========================= */

.global-loader{

position:fixed;

inset:0;

background:rgba(0,0,0,.7);

display:flex;

justify-content:center;

align-items:center;

z-index:99999;

backdrop-filter:blur(10px);

}

.spinner-loader{

width:70px;
height:70px;

border-radius:50%;

border:
6px solid rgba(255,255,255,.1);

border-top:
6px solid #2563eb;

animation:
spin 1s linear infinite;

}

@keyframes spin{

100%{

transform:rotate(360deg);

}

}

/* =========================
THEME BUTTON
========================= */

#themeToggle{

position:fixed;

top:20px;

right:20px;

padding:14px 18px;

border:none;

border-radius:14px;

background:#2563eb;

color:white;

cursor:pointer;

z-index:999;

}

/* =========================
NEON EFFECT
========================= */

.neon{

box-shadow:
0 0 20px rgba(37,99,235,.6),
0 0 40px rgba(37,99,235,.4);

}

/* =========================
GLASS EFFECT
========================= */

.glass{

background:
rgba(255,255,255,.05);

backdrop-filter:
blur(20px);

border:
1px solid rgba(255,255,255,.1);

}
/* =========================
AI ASSISTANT
========================= */

.ai-assistant{

position:fixed;

bottom:100px;

right:20px;

width:320px;

background:#0f172a;

padding:20px;

border-radius:24px;

z-index:999;

box-shadow:
0 0 20px rgba(37,99,235,.3);

}

.ai-assistant input{

width:100%;

padding:14px;

border:none;

border-radius:14px;

background:#1e293b;

color:white;

margin-bottom:10px;

}

.ai-assistant button{

width:100%;

padding:14px;

border:none;

border-radius:14px;

background:#2563eb;

color:white;

cursor:pointer;

}

/* =========================
INSTALL BUTTON
========================= */

#installAppBtn{

position:fixed;

bottom:20px;

left:20px;

padding:15px 20px;

border:none;

border-radius:14px;

background:#2563eb;

color:white;

cursor:pointer;

display:none;

z-index:999;

}

/* =========================
LIGHT MODE
========================= */

.light-mode{

background:#f8fafc;

color:#020617;

}

.light-mode .product-card,
.light-mode .stats-card,
.light-mode .order-card,
.light-mode .tracking-box,
.light-mode .order-box,
.light-mode .sidebar,
.light-mode .admin-sidebar{

background:#ffffff;

color:#020617;

}

.light-mode input,
.light-mode textarea,
.light-mode select{

background:#e2e8f0;

color:#020617;

}

/* =========================
SCROLLBAR
========================= */

::-webkit-scrollbar{

width:8px;

}

::-webkit-scrollbar-thumb{

background:#2563eb;

border-radius:20px;

}

/* =========================
PORTFOLIO
========================= */

.portfolio-grid{

display:grid;

grid-template-columns:
repeat(auto-fit,minmax(300px,1fr));

gap:25px;

}

.portfolio-card{

background:#0f172a;

border-radius:24px;

overflow:hidden;

transition:.3s;

}

.portfolio-card:hover{

transform:translateY(-5px);

}

.portfolio-card img{

width:100%;

height:250px;

object-fit:cover;

}

.portfolio-card h3{

padding:20px;

color:white;

}

}
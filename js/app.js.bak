import { db } from "./firebase.js";

import {
ref,
push
}
from "https://www.gstatic.com/firebasejs/12.13.0/firebase-database.js";

/* =========================
APP START
========================= */

alert("APP JS HIDUP");

/* =========================
PRODUCT DATA
========================= */

const products = [

{
name: 'Dana Premium',
price: 'Rp35.000'
},

{
name: 'QRIS Merchant',
price: 'Rp45.000'
},

{
name: 'Video Editing',
price: 'Rp75.000'
}

];

/* =========================
RENDER PRODUCTS
========================= */

const productGrid =
document.getElementById('productGrid');

if(productGrid){

products.forEach((product)=>{

productGrid.innerHTML += `

<div class="product-card">

<h3>${product.name}</h3>

<p>${product.price}</p>

<button
class="btn-primary order-btn"
data-product="${product.name}">

Order Sekarang

</button>

</div>

`;

});

}

/* =========================
SLIDER
========================= */

let slideIndex = 0;

const sliderTrack =
document.getElementById('sliderTrack');

if(sliderTrack){

setInterval(()=>{

slideIndex++;

if(slideIndex > 2){
slideIndex = 0;
}

sliderTrack.style.transform =
`translateX(-${slideIndex * 100}%)`;

},4000);

}

/* =========================
FAQ
========================= */

const faqButtons =
document.querySelectorAll('.faq-question');

faqButtons.forEach((button)=>{

button.addEventListener('click',()=>{

const answer =
button.nextElementSibling;

answer.style.display =

answer.style.display === 'block'
? 'none'
: 'block';

});

});

/* =========================
GENERATE ORDER ID
========================= */

function generateOrderId(){

const random =
Math.floor(
1000 + Math.random() * 9000
);

return `ORD-${random}`;

}

/* =========================
ORDER BUTTON
========================= */

document.addEventListener(
'click',
async function(e){

if(
e.target.classList.contains('order-btn')
){

const product =
e.target.dataset.product;

await submitOrder(product);

}

}
);

/* =========================
SUBMIT ORDER
========================= */

async function submitOrder(product){

const customerName =
prompt('Masukkan Nama');

const customerWa =
prompt('Masukkan Nomor WhatsApp');

if(
!customerName ||
!customerWa
){

alert('Data belum lengkap');

return;

}

const orderId =
generateOrderId();

try{

const orderRef =
ref(db,'orders');

await push(orderRef,{

orderId,

name:
customerName,

wa:
customerWa,

product:
product,

status:
'Pending',

createdAt:
Date.now()

});

alert(
`Pesanan berhasil dibuat\n\nOrder ID: ${orderId}`
);

const message =

`Halo Admin,
Saya ingin order.

Order ID: ${orderId}

Produk: ${product}

Nama: ${customerName}

WhatsApp: ${customerWa}`;

window.open(

`https://wa.me/6285609949819?text=${encodeURIComponent(message)}`,

'_blank'

);

}
catch(error){

console.error(error);

alert(
'Terjadi error saat membuat pesanan'
);

}

}
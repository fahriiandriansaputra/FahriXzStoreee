import {

initializeApp

}

from

'https://www.gstatic.com/firebasejs/10.12.2/firebase-app.js';

import {

getStorage,
ref,
getDownloadURL

}

from

'https://www.gstatic.com/firebasejs/10.12.2/firebase-storage.js';

const firebaseConfig = {

apiKey:"YOUR_API_KEY",

authDomain:
"YOUR_PROJECT.firebaseapp.com",

projectId:
"YOUR_PROJECT_ID",

storageBucket:
"YOUR_BUCKET.appspot.com",

messagingSenderId:
"YOUR_SENDER_ID",

appId:
"YOUR_APP_ID"

};

const app =
initializeApp(firebaseConfig);

const storage =
getStorage(app);

/* =========================
DOWNLOAD FILE
========================= */

window.downloadResult =
async function(fileName){

const fileRef =
ref(
storage,
'results/' + fileName
);

const url =
await getDownloadURL(
fileRef
);

window.open(url);

};